DEBUG=False
SECRET_KEY=change-me-before-production
ALLOWED_HOSTS=barberflow-api.onrender.com,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://barberflow-web.onrender.com,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=https://barberflow-api.onrender.com,https://barberflow-web.onrender.com
